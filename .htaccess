# Infouno — Headers de seguridad (M3 de la auditoría: ai/security-audit.md)
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set Content-Security-Policy-Report-Only "default-src 'self'; script-src 'self' https://www.googletagmanager.com; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com; img-src 'self' data: https://www.google-analytics.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; frame-src https://cal.com https://*.cal.com https://calendly.com https://*.calendly.com; base-uri 'self'; form-action 'self'"
</IfModule>

Options -Indexes

# Bloquear acceso directo a config y archivos sensibles (defense-in-depth).
# config.php es PHP (no filtra fuente), pero negamos el acceso por las dudas.
<FilesMatch "^(config\.php|config\.sample\.php)$">
  Require all denied
</FilesMatch>